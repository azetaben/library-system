{
  "name": "acceptance-test",
  "version": "1.0.0",
  "private": true,
  "description": "TypeScript end-to-end automation framework using Cucumber, Playwright, and Allure reporting for UI acceptance tests.",
  "license": "ISC",
  "author": "BA",
  "type": "module",
  "scripts": {
    "test": "npm run test:e2e",
    "test:features": "npm run test:e2e",
    "test:e2e": "cross-env FORCE_COLOR=1 node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js",
    "posttest:e2e": "npm run report:cucumber",
    "test:e2e:headed": "cross-env FORCE_COLOR=1 HEADLESS=false node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js",
    "test:e2e:report": "npm run test:e2e",
    "test:features:auth": "cross-env FORCE_COLOR=1 node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js features/auth/**/*.feature",
    "test:features:create-book": "cross-env FORCE_COLOR=1 node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js features/create-book/**/*.feature",
    "test:features:delete-book": "cross-env FORCE_COLOR=1 node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js features/delete-book/**/*.feature",
    "test:features:e2e": "cross-env FORCE_COLOR=1 node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js features/e2e/**/*.feature",
    "test:features:edit-book": "cross-env FORCE_COLOR=1 node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js features/edit-book/**/*.feature",
    "test:features:performance": "cross-env FORCE_COLOR=1 node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js features/performance/**/*.feature",
    "test:features:accessibility": "cross-env FORCE_COLOR=1 node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js features/accessibility/**/*.feature",
    "test:accessibility:wcag-2.2": "cross-env FORCE_COLOR=1 node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js features/accessibility/tc-28-wcag-2.2-compliance.feature",
    "test:accessibility:wcag-2.2:headed": "cross-env FORCE_COLOR=1 HEADLESS=false node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js features/accessibility/tc-28-wcag-2.2-compliance.feature",
    "test:accessibility:wcag-critical": "cross-env FORCE_COLOR=1 node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js features/accessibility/tc-28-wcag-2.2-compliance.feature --tags '@wcag-2.2-critical'",
    "test:features:ui-test": "cross-env FORCE_COLOR=1 node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js features/ui-test/**/*.feature",
    "test:features:view-book": "cross-env FORCE_COLOR=1 node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js features/view-book/**/*.feature",
    "test:visual": "cross-env FORCE_COLOR=1 node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js features/visual-test/tc-27-visual-core-pages.feature",
    "test:visual:update-baseline": "cross-env FORCE_COLOR=1 VISUAL_UPDATE_BASELINE=true node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js features/visual-test/tc-27-visual-core-pages.feature",
    "test:feature:file": "cross-env FORCE_COLOR=1 node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js",
    "test:cross-browser:login": "cross-env HEADLESS=false node scripts/run-cross-browser-login.mjs",
    "test:cross-browser:login:firefox": "cross-env HEADLESS=false CROSS_BROWSER_BROWSERS=firefox node scripts/run-cross-browser-login.mjs",
    "test:cross-browser:login:firefox-webkit": "cross-env HEADLESS=false CROSS_BROWSER_BROWSERS=firefox,webkit node scripts/run-cross-browser-login.mjs",
    "test:cross-browser:login:webkit": "cross-env HEADLESS=false CROSS_BROWSER_BROWSERS=webkit node scripts/run-cross-browser-login.mjs",
    "test:cross-browser:login:headless": "cross-env HEADLESS=true node scripts/run-cross-browser-login.mjs",
    "test:cross-browser:login:firefox-webkit:headless": "cross-env HEADLESS=true CROSS_BROWSER_BROWSERS=firefox,webkit node scripts/run-cross-browser-login.mjs",
    "test:cross-browser:login:dry-run": "cross-env HEADLESS=false node scripts/run-cross-browser-login.mjs --dry-run",
    "test:cross-browser:login:firefox-webkit:dry-run": "cross-env HEADLESS=false CROSS_BROWSER_BROWSERS=firefox,webkit node scripts/run-cross-browser-login.mjs --dry-run",
    "test:dry-run": "cross-env FORCE_COLOR=1 node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js -p dryRun",
    "test:smoke": "cross-env FORCE_COLOR=1 node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js -p smoke",
    "test:regression": "cross-env FORCE_COLOR=1 node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js -p regression",
    "test:bug": "cross-env FORCE_COLOR=1 node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js -p bug",
    "test:security": "cross-env FORCE_COLOR=1 node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js -p security",
    "test:performance": "cross-env FORCE_COLOR=1 node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js -p performance",
    "test:workflow": "cross-env FORCE_COLOR=1 node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js -p workflow",
    "test:ui-contract": "cross-env FORCE_COLOR=1 node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js -p uiContract",
    "test:debug": "cross-env FORCE_COLOR=1 node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js -p debug",
    "test:playwright": "playwright test",
    "test:playwright:azure": "cross-env CI=true HEADLESS=true FORCE_COLOR=1 playwright test",
    "report:cucumber": "node scripts/generate-multi-cucumber-report.mjs",
    "report:cucumber:firefox": "cross-env BROWSER=firefox node scripts/generate-multi-cucumber-report.mjs",
    "report:cucumber:webkit": "cross-env BROWSER=webkit node scripts/generate-multi-cucumber-report.mjs",
    "report:pdf": "node docs/generate-about-framework-pdf.mjs",
    "report:allure": "npm run allure:generate",
    "report:all": "npm run report:cucumber && npm run report:allure && npm run report:pdf",
    "test:e2e:reports": "npm run test:e2e && npm run report:all",
    "ci:azure:install": "npm ci && npx playwright install --with-deps",
    "ci:azure:e2e": "cross-env CI=true HEADLESS=true FORCE_COLOR=1 node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js",
    "ci:azure:e2e:reports": "cross-env CI=true HEADLESS=true FORCE_COLOR=1 npm run test:e2e:reports",
    "ci:azure:playwright": "cross-env CI=true HEADLESS=true FORCE_COLOR=1 playwright test",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@cucumber/cucumber": "^12.7.0",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.59.1",
    "@types/fs-extra": "^11.0.4",
    "@types/luxon": "^3.7.1",
    "@types/mssql": "^9.1.5",
    "@types/node": "^22.10.0",
    "@types/oracledb": "^6.5.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.18.0",
    "allure-commandline": "^2.37.0",
    "allure-cucumberjs": "^3.6.0",
    "allure-playwright": "^3.6.0",
    "cross-env": "^7.0.3",
    "csv-parse": "^5.5.6",
    "dotenv": "^17.3.1",
    "luxon": "^3.4.3",
    "mkdirp": "^3.0.1",
    "moment": "^2.30.1",
    "mongodb": "^7.1.0",
    "mssql": "^11.0.1",
    "multiple-cucumber-html-reporter": "^3.10.0",
    "mysql2": "^3.9.1",
    "pdf-parse": "^1.1.1",
    "playwright": "^1.59.1",
    "postcss": "^8.5.8",
    "prettier": "^3.3.1",
    "rollup": "^4.60.1",
    "source-map-js": "^1.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2"
  }
}
