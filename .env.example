# Active environment: dev | staging | prod
TEST_ENV=dev

# Base URLs
# DEV_BASE_URL is the primary required URL.
# BASE_URL remains supported as a backward-compatible fallback.
DEV_BASE_URL=https://frontendui-librarysystem.onrender.com
STAGING_BASE_URL=https://frontendui-librarysystem.onrender.com
PROD_BASE_URL=https://frontendui-librarysystem.onrender.com
BASE_URL=https://frontendui-librarysystem.onrender.com

# Credentials
TEST_USERNAME=
TEST_PASSWORD=

# Browser/runtime
BROWSER=chromium
HEADLESS=false
SLOW_MO_MS=0
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=720
ACCEPT_DOWNLOADS=true
IGNORE_HTTPS_ERRORS=true

# Timeout policy
CUCUMBER_TIMEOUT_MS=120000
ACTION_TIMEOUT_MS=10000
EXPECT_TIMEOUT_MS=10000
DEFAULT_TIMEOUT_MS=15000
NAVIGATION_TIMEOUT_MS=30000
RESPONSIVE_WARMUP_TIMEOUT_MS=90000
RESPONSIVE_POLL_INTERVAL_MS=1500
RESPONSIVE_REQUEST_TIMEOUT_MS=4000
RESPONSIVE_CACHE_TTL_MS=180000

# Optional Playwright web server
PLAYWRIGHT_WEB_SERVER_COMMAND=
PLAYWRIGHT_WEB_SERVER_URL=
